# LSPay environment variables
# Copy this file to ".env" and fill in your real values.
# All Vite client env vars MUST be prefixed with VITE_.

# Paystack publishable key (used by the parent wallet top-up flow).
# Found in your Paystack dashboard under Settings > API Keys & Webhooks.
VITE_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase project credentials (Project Settings > API).
# VITE_SUPABASE_URL is the "Project URL".
# VITE_SUPABASE_ANON_KEY is the public "anon" key (safe to expose in the browser).
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
